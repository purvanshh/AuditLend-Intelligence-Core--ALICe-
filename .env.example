# Database
DATABASE_URL=postgresql://auditlend:auditlend@postgres:5432/auditlend
ASYNC_DATABASE_URL=postgresql+asyncpg://auditlend:auditlend@postgres:5432/auditlend
# Optional. Use "null" only for multi-event-loop test harnesses.
AUDITLEND_ASYNC_DB_POOL=pooled

# Redis
REDIS_URL=redis://redis:6379/0
IDEMPOTENCY_CACHE_TTL_SECONDS=86400

# Mock External APIs
CREDIT_BUREAU_URL=http://credit-bureau:8001
BANK_ANALYZER_URL=http://bank-analyzer:8002
GST_VERIFIER_URL=http://gst-verifier:8003

# Decision Engine
CONFIDENCE_THRESHOLD=0.6

# === PRODUCTION SECRETS (REQUIRED; application refuses insecure values) ===
# Generate with: python -c "import os; print(os.urandom(32).hex())"
PII_ENCRYPTION_KEY=change-me-to-a-real-64-char-hex-string
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PAN_HASH_SALT=change-me-to-a-real-random-salt

# Comma-separated API keys. Optional scope suffixes: :read, :write, :read-write.
API_KEYS=dev-key-read-write:read-write,dev-key-read-only:read

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_WINDOW_SECONDS=60
CIRCUIT_BREAKER_TIMEOUT_SECONDS=120
CIRCUIT_BREAKER_PROBE_LOCK_SECONDS=10

# Retry
MAX_RETRIES=3
RETRY_BACKOFF_BASE_SECONDS=2
EXTERNAL_API_TIMEOUT_SECONDS=30.0

# Processing
TASK_TIMEOUT_SECONDS=60
PROCESSING_LOCK_TIMEOUT_SECONDS=300
OUTBOX_POLL_INTERVAL_SECONDS=1.0
WORKER_HEALTH_PORT=8004

# API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
